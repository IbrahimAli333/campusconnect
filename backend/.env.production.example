UNIVERSITY_PORTAL_APP_NAME="Unibridge API"
UNIVERSITY_PORTAL_API_V1_PREFIX="/api/v1"
UNIVERSITY_PORTAL_DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE"
UNIVERSITY_PORTAL_ENVIRONMENT="production"
UNIVERSITY_PORTAL_SECRET_KEY="replace-with-a-long-random-secret-from-a-password-manager"
UNIVERSITY_PORTAL_ALGORITHM="HS256"
UNIVERSITY_PORTAL_ACCESS_TOKEN_EXPIRE_MINUTES=60
UNIVERSITY_PORTAL_CORS_ORIGINS="https://your-campusconnect-web-domain.com"
