{
  "name": "university-portal",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "node --stack-size=8192 node_modules/typescript/lib/tsc.js --noEmit",
    "doctor": "npx expo-doctor",
    "publish:check": "node scripts/verify-publish-env.js",
    "build:android:preview": "npm run publish:check && npx eas build --platform android --profile preview",
    "build:ios:preview": "npm run publish:check && npx eas build --platform ios --profile preview",
    "build:android:production": "npm run publish:check && npx eas build --platform android --profile production",
    "build:ios:production": "npm run publish:check && npx eas build --platform ios --profile production",
    "submit:android": "npx eas submit --platform android --profile production",
    "submit:ios": "npx eas submit --platform ios --profile production"
  },
  "private": true
}
